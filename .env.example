# Copy to .env and fill in real values. Never commit .env.
# DATABASE_URL below is for running the backend outside Docker Compose (host port 5433).
# docker-compose.yml overrides it to use the postgres service hostname on port 5432.
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5433/market_feature_store
PROVIDER_API_KEY=your-alpaca-key-id-here
PROVIDER_API_SECRET=your-alpaca-secret-key-here
PROVIDER_NAME=alpaca
ENVIRONMENT=development
LOG_LEVEL=INFO
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=market_feature_store
# Optional — only needed when running with --profile minio
MINIO_ROOT_PASSWORD=minioadmin
# Optional — enable S3/MinIO sink for large raw payloads (off by default)
# For local runs outside Docker:
# S3_ENDPOINT_URL=http://localhost:9000
# Docker Compose overrides this to http://minio:9000 for the backend service.
# S3_BUCKET=raw-market-data
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_REGION=us-east-1
# RAW_PAYLOAD_S3_THRESHOLD_BYTES=262144
