# Copy to .env and fill in real values. Never commit .env.
# DATABASE_URL below is for running the backend outside Docker Compose (host port 5433).
# docker-compose.yml overrides it to use the postgres service hostname on port 5432.
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5433/market_feature_store
PROVIDER_API_KEY=your-api-key-here
ENVIRONMENT=development
LOG_LEVEL=INFO
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=market_feature_store
# Optional — only needed when running with --profile minio
MINIO_ROOT_PASSWORD=minioadmin
